# Config file for the arjun package.
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(sbva REQUIRED CONFIG)
find_dependency(treedecomp REQUIRED CONFIG)

set_and_check(ARJUN_INCLUDE_DIRS "@PACKAGE_ARJUN_INSTALL_INCLUDEDIR@")
include("${CMAKE_CURRENT_LIST_DIR}/arjunTargets.cmake")
set(ARJUN_LIBRARIES arjun)
set(ARJUN_STATIC_LIBRARIES arjun)
set(ARJUN_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(ARJUN_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(ARJUN_EXECUTABLE arjun)

check_required_components(arjun)
